{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "leetbytes-client",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--dir", "client", "exec", "next", "dev", "-p", "3001"],
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "leetbytes-server",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--dir", "server", "run", "dev"],
      "port": 4001,
      "env": { "PORT": "4001" },
      "autoPort": false
    }
  ]
}
